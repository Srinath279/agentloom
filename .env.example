# Copy to .env before running the worker. This project's Flox on-activate
# hook sources .env into the activated environment (see
# .flox/env/manifest.toml and docs/services/flox.md) — that's what makes
# these reach the `worker` service. worker.py itself has no dotenv loading.
#
# IMPORTANT: if services are already running, editing .env alone isn't
# enough — `flox services restart <name>` reuses the environment the
# service manager captured at its first `flox services start`. Apply an
# env change with `flox services stop` followed by
# `flox activate --start-services`.
OPENROUTER_API_KEY=sk-or-v1-...
TEMPORAL_ADDRESS=localhost:7233

# To run against a local model server instead of OpenRouter (e.g. Ollama on
# this machine's GPU), set these two and OPENROUTER_API_KEY is not needed:
# LLM_BASE_URL=http://localhost:11434/v1/chat/completions
# LLM_MODEL=qwen2.5:14b-instruct

# Langfuse tracing (see observability/langfuse/.env for the local dev values —
# already wired into the Flox environment's [vars] in .flox/env/manifest.toml,
# so these only need setting here if you're running the worker without Flox).
# LANGFUSE_HOST=http://localhost:3001
# LANGFUSE_PUBLIC_KEY=pk-lf-agentloom-local
# LANGFUSE_SECRET_KEY=sk-lf-agentloom-local
