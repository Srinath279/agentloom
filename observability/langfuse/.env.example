# Local-dev overrides for the Langfuse docker-compose stack.
# Copy to .env (gitignored) and fill in your own values before running
# `flox activate --start-services` (or `docker compose up` directly).

# Langfuse web is remapped to :3001 (Grafana owns :3000)
NEXTAUTH_URL=http://localhost:3001

# MinIO host port remapped to :9190 (Prometheus owns :9090)
LANGFUSE_S3_MEDIA_UPLOAD_ENDPOINT=http://localhost:9190
LANGFUSE_S3_BATCH_EXPORT_EXTERNAL_ENDPOINT=http://localhost:9190

# Seed an org/project/user + API keys on first boot so tracing works
# immediately without manual UI setup. Point LANGFUSE_PUBLIC_KEY /
# LANGFUSE_SECRET_KEY in .flox/env/manifest.toml at whatever you set here.
LANGFUSE_INIT_ORG_ID=agentloom
LANGFUSE_INIT_ORG_NAME=AgentLoom
LANGFUSE_INIT_PROJECT_ID=agentloom
LANGFUSE_INIT_PROJECT_NAME=agentloom
LANGFUSE_INIT_PROJECT_PUBLIC_KEY=pk-lf-agentloom-local
LANGFUSE_INIT_PROJECT_SECRET_KEY=sk-lf-agentloom-local
LANGFUSE_INIT_USER_EMAIL=you@example.com
LANGFUSE_INIT_USER_NAME=Your Name
LANGFUSE_INIT_USER_PASSWORD=change-me-locally
